# QGIS lock files only — NOT the project file
*.qgz~
*.qgs~
*.lock

# GeoPackage WAL/SHM lock files (safe to exclude, auto-regenerated)
*.gpkg-shm
*.gpkg-wal

# OS files
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.py[cod]
.env

# Zip archives (use releases instead)
*.zip

# NOTE: GeoTIFFs (.tif) and GeoPackages (.gpkg) ARE included in this repo.
# Raw rasters from GEE are in GEE_DATA/ and Processed/ — these are the
# source truth for all numbers in the stats CSV.
